VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# IMPORTANT: This must be your Supabase "anon public" key (NOT the service_role key).
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# Where Supabase should redirect after email confirmation.
# Set this to your production URL when deploying.
VITE_EMAIL_REDIRECT_TO=<your-site-url>

